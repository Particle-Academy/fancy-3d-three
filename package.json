{
  "name": "@particle-academy/fancy-3d-three",
  "version": "0.1.1",
  "description": "three.js adapter for @particle-academy/fancy-3d — WebGL renderer, primitives, React components (Stage, Monitor, Card3D, Screen) that mount onto a three.js Scene.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Particle-Academy/fancy-3d-three.git"
  },
  "homepage": "https://github.com/Particle-Academy/fancy-3d-three#readme",
  "bugs": "https://github.com/Particle-Academy/fancy-3d-three/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./engine": {
      "import": {
        "types": "./dist/engine.d.ts",
        "default": "./dist/engine.js"
      },
      "require": {
        "types": "./dist/engine.d.cts",
        "default": "./dist/engine.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "react",
    "3d",
    "three",
    "threejs",
    "webgl",
    "fancy-3d"
  ],
  "peerDependencies": {
    "@particle-academy/fancy-3d": "^0.4.0",
    "@particle-academy/react-fancy": ">=3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "@particle-academy/react-fancy": {
      "optional": true
    }
  },
  "devDependencies": {
    "@particle-academy/fancy-3d": "^0.4.0",
    "@particle-academy/react-fancy": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.184.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
